{
	"name": "frontend",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"dev:client1": "vite dev --host 127.0.0.1 --port 5173 --strictPort",
		"dev:client2": "vite dev --host 127.0.0.1 --port 5174 --strictPort",
		"desktop:dev": "tauri dev",
		"desktop:dev:client1": "tauri dev",
		"desktop:dev:client2": "tauri dev --config src-tauri/tauri.client2.conf.json",
		"desktop:build": "tauri build",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@tauri-apps/api": "^2.10.1",
		"@tauri-apps/cli": "^2.10.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"daisyui": "^5.5.19"
	}
}
